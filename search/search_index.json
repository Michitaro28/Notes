8</li> </ul>"},{"location":"%E9%96%8B%E7%99%BA/Django/Django/#_1","title":"\u53c2\u8003\u30b5\u30a4\u30c8","text":"<ul> <li>Python\u3055\u3048\u5206\u304b\u308c\u3070Django\u3067Web\u30a2\u30d7\u30ea\u306f\u4f5c\u308c\u308b</li> </ul>"},{"location":"%E9%96%8B%E7%99%BA/Django/Django/#mvt","title":"MVT\u30e2\u30c7\u30eb\u306b\u3064\u3044\u3066","text":"<ul> <li>Model\u306e\u307e\u3068\u3081</li> </ul> \u9805\u76ee \u8a73\u7d30 \u5f79\u5272 \u30e2\u30c7\u30eb\u306f\u30c7\u30fc\u30bf\u30d9\u30fc\u30b9\u306e\u3084\u308a\u53d6\u308a\u3092\u62c5\u5f53\u3057\u3001\u30c7\u30fc\u30bf\u306e\u7a2e\u985e\u3084\u4fdd\u5b58\u306e\u30eb\u30fc\u30eb\u3092\u6c7a\u3081\u3001\u30a2\u30d7\u30ea\u30b1\u30fc\u30b7\u30e7\u30f3\u306e\u4e2d\u3067\u60c5\u5831\u3092\u7ba1\u7406\u3059\u308b\u3002 \u5bfe\u8c61\u30d5\u30a1\u30a4\u30eb models.py\u306b\u30c7\u30fc\u30bf\u30d9\u30fc\u30b9\u3068\u3093\u3084\u308a\u53d6\u308a\u3092\u3059\u308b\u65b9\u6cd5\u3092\u66f8\u304f\u3002 \u4f8b \u30e6\u30fc\u30b6\u30fc\u60c5\u5831\u3092\u4fdd\u5b58\u3059\u308b\u30e2\u30c7\u30eb\u3092\u4f5c\u308b\u3068\u3001\u540d\u524d\u3084\u30e1\u30fc\u30eb\u30a2\u30c9\u30ec\u30b9\u3093\u3069\u3092\u30c7\u30fc\u30bf\u30d9\u30fc\u30b9\u306b\u8a18\u9332\u3067\u304d\u308b\u3088\u3046\u306b\u306a\u308b\u3002 <ul> <li>View\u306e\u307e\u3068\u3081</li> </ul> \u9805\u76ee \u8a73\u7d30 \u5f79\u5272 \u30e6\u30fc\u30b6\u30fc\u306e\u30ea\u30af\u30a8\u30b9\u30c8\u3092\u53d7\u3051\u53d6\u308a\u3001\u5fc5\u8981\u306a\u51e6\u7406\u3092\u3057\u3066\u3001\u30c7\u30fc\u30bf\u3092\u30c6\u30f3\u30d7\u30ec\u30fc\u30c8\u306b\u6e21\u3059\u3002 \u5bfe\u8c61\u30d5\u30a1\u30a4\u30eb views.py\u306b\u30e6\u30fc\u30b6\u30fc\u306e\u64cd\u4f5c\u306b\u5fdc\u3058\u305f\u51e6\u7406\u3092\u66f8\u304f\u3002 \u4f8b \u30e6\u30fc\u30b6\u30fc\u304cWEB\u30b5\u30a4\u30c8\u306b\u30a2\u30af\u30bb\u30b9\u3059\u308b\u3068\u3001\u30d3\u30e5\u30fc\u306f\u300c\u30e6\u30fc\u30b6\u30fc\u60c5\u5831\u300d\u3092\u53d6\u308a\u51fa\u3057\u3066\u3001WEB\u30da\u30fc\u30b8\u306b\u8868\u793a\u3057\u307e\u3059\u3002 <ul> <li>Template\u306e\u307e\u3068\u3081</li> </ul> \u9805\u76ee \u8a73\u7d30 \u5f79\u5272 Template\u306fHTML\u30d5\u30a1\u30a4\u30eb\u3067\u30da\u30fc\u30b8\u30c7\u30b6\u30a4\u30f3\u3084\u30ec\u30a4\u30a2\u30a6\u30c8\u3092\u6c7a\u3081\u307e\u3059\u3002\u53d7\u3051\u53d6\u3063\u305f\u30c7\u30fc\u30bf\u3092\u300c\u898b\u3048\u308b\u5f62\u300d\u306b\u3057\u3066\u8868\u793a\u3057\u307e\u3059\u3002 \u5bfe\u8c61\u30d5\u30a1\u30a4\u30eb templates\u3068\u3044\u3046\u30d5\u30a9\u30eb\u30c0\u306e\u4e2d\u306bHTML\u30d5\u30a1\u30a4\u30eb\u3092\u7f6e\u304d\u307e\u3059\u3002 \u4f8b HTML\u30d5\u30a1\u30a4\u30eb\u306b\u300c\u540d\u524d\u300d\u300c\u30e1\u30fc\u30eb\u30a2\u30c9\u30ec\u30b9\u300d\u306a\u3069\u3092\u8868\u793a\u3059\u308b\u30ec\u30a4\u30a2\u30a6\u30c8\u3092\u4f5c\u308a\u307e\u3059\u3002\u30d3\u30e5\u30fc\u304b\u3089\u6e21\u3055\u308c\u305f\u30e6\u30fc\u30b6\u30fc\u60c5\u5831\u304c\u3053\u3053\u306b\u53cd\u6620\u3055\u308c\u308b\u3002"},{"location":"%E9%96%8B%E7%99%BA/Django/Django/#mvt_1","title":"MVT\u30e2\u30c7\u30eb\u306e\u52d5\u304d","text":"<p>\u30b9\u30c6\u30c3\u30d7 1. \u30ea\u30af\u30a8\u30b9\u30c8 2. URL\u30c7\u30a3\u30b9\u30d1\u30c3\u30c1\u30e3 3. View\u3067\u306e\u51e6\u7406 4. Model\u304b\u3089\u30c7\u30fc\u30bf\u53d6\u5f97 5. View\u306b\u30c7\u30fc\u30bf\u3092\u6e21\u3059 6. \u30c6\u30f3\u30d7\u30ec\u30fc\u30c8\u306b\u8868\u793a\u8981\u6c42 7. \u30c7\u30fc\u30bf\u8868\u793a 8. \u30ec\u30b9\u30dd\u30f3\u30b9</p> <p>URL\u30c7\u30a3\u30b9\u30d1\u30c3\u30c1\u30e3\u3068\u306f Django\u306e\u300cURL\u30c7\u30a3\u30b9\u30d1\u30c3\u30c1\u30e3\u300d\u306f\u3001\u30e6\u30fc\u30b6\u30fc\u304cWEB\u30b5\u30a4\u30c8\u306b\u30a2\u30af\u30bb\u30b9\u3057\u305f\u969b\u306b\u3001\u3069\u306e\u30d3\u30e5\u30fc\uff08\u51e6\u7406\uff09\u3092\u547c\u3073\u51fa\u3059\u304b\u3092\u6c7a\u3081\u308b\u5f79\u5272\u3092\u62c5\u3063\u3066\u3044\u308b\u3002\u30e6\u30fc\u30b6\u30fc\u304c\u5165\u529b\u3057\u305fURL\u3092\u5143\u306b\u3069\u306e\u51e6\u7406\u3092\u5b9f\u884c\u3059\u308b\u3079\u304d\u304b\u3092\u5224\u65ad\u3057\u3001\u300c\u30ea\u30af\u30a8\u30b9\u30c8\u300d\u3092\u9069\u5207\u306a\u300c\u30d3\u30e5\u30fc\u300d\u306b\u9001\u308a\u307e\u3059\u3002</p>"},{"location":"%E9%96%8B%E7%99%BA/Django/Django/#_2","title":"\u30b5\u30fc\u30d0\u30fc\u5074\u306e\u51e6\u7406","text":"<p>Django\u51e6\u7406\u306e\u5168\u4f53\u69cb\u6210 </p> <p>\u30b9\u30c6\u30c3\u30d7 1. \u30e6\u30fc\u30b6\u30fc\u304c\u30d6\u30e9\u30a6\u30b6\u3067URL\u3092\u5165\u529b\u3057\u3001WEB\u30b5\u30a4\u30c8\u306b\u30a2\u30af\u30bb\u30b9\u3057\u307e\u3059\u3002 2. Django\u304c\u305d\u306eURL\u306b\u5fdc\u3058\u3066\u3001\u3069\u306e\u51e6\u7406\u3092\u884c\u3046\u304b\u3092\u6c7a\u3081\u3001\u5bfe\u8c61\u306eviews.py\u306e\u51e6\u7406\u3092\u547c\u3073\u51fa\u3057\u307e\u3059\u3002 3. \u30ea\u30af\u30a8\u30b9\u30c8\u306b\u5fdc\u3058\u3066\u3001\u30c7\u30fc\u30bf\u30d9\u30fc\u30b9\uff08models.py\uff09\u304b\u3089\u60c5\u5831\u3092\u53d6\u308a\u51fa\u3057\u305f\u308a\u3001\u30c6\u30f3\u30d7\u30ec\u30fc\u30c8\uff08HTML\u30d5\u30a1\u30a4\u30eb\uff09\u3092\u4f7f\u7528\u3057\u3066\u30da\u30fc\u30b8\u3092\u4f5c\u308a\u307e\u3059\u3002 4. \u5b8c\u6210\u3057\u305fWEB\u30da\u30fc\u30b8\u304c\u3001\u30e6\u30fc\u30b6\u30fc\u306e\u30d6\u30e9\u30a6\u30b6\u306b\u8868\u793a\u3055\u308c\u307e\u3059\u3002</p> <p>\u30b5\u30fc\u30d0\u30fc\u5074\u306e\u307e\u3068\u3081</p> \u30d5\u30a1\u30a4\u30eb\u540d \u8a73\u7d30 urls.py WEB\u30b5\u30a4\u30c8\u306e\u30a2\u30c9\u30ec\u30b9\uff08URL\uff09\u3068\u3001\u305d\u306e\u30a2\u30c9\u30ec\u30b9\u306b\u30a2\u30af\u30bb\u30b9\u3057\u305f\u6642\u306b\u306b\u306a\u3092\u3059\u308b\u304b\u3092\u6c7a\u3081\u308b\u300c\u9053\u6a19\u300d\u3067\u3059\u3002URL\u30c7\u30a3\u30b9\u30d1\u30c3\u30c1\u30e3\u306e\u5f79\u5272\u3067\u3059\u3002 views.py \u30ea\u30af\u30a8\u30b9\u30c8\u3092\u53d7\u3051\u53d6\u308a\u3001\u5fc5\u8981\u306a\u51e6\u7406\u3092\u884c\u3044\u3001\u7d50\u679c\u3092\u8fd4\u3059\u300c\u982d\u8133\u300d\u306e\u90e8\u5206\u3067\u3059\u3002\u30c7\u30fc\u30bf\u3092\u3068\u308a\u3060\u3057\u3066\u753b\u9762\u306b\u8868\u793a\u3055\u305b\u308b\u5f79\u5272 models.py \u30c7\u30fc\u30bf\u30d9\u30fc\u30b9\u3068\u3084\u308a\u53d6\u308a\u3092\u884c\u3046\u5834\u6240\u3067\u3059\u3002\u4fdd\u5b58\u3057\u305f\u3044\u30c7\u30fc\u30bf\u306e\u300c\u5f62\uff08\u69cb\u9020\uff09\u300d\u3092\u6c7a\u3081\u307e\u3059\u3002 templates HTML\u30d5\u30a1\u30a4\u30eb\u3092\u683c\u7d0d\u3059\u308b\u30d5\u30a9\u30eb\u30c0\u3067\u3059\u3002WEB\u30da\u30fc\u30b8\u306e\u898b\u305f\u76ee\u3092\u4f5c\u308b\u5834\u6240\u3067\u3059\u3002"},{"location":"%E9%96%8B%E7%99%BA/Django/%E5%AE%9F%E8%A3%85%E3%83%A1%E3%83%A2/","title":"\u5b9f\u88c5\u306b\u304a\u3051\u308b\u30e1\u30e2","text":""},{"location":"%E9%96%8B%E7%99%BA/Django/%E5%AE%9F%E8%A3%85%E3%83%A1%E3%83%A2/#pakage","title":"pakage","text":"<ul> <li>uv\u3092\u4f7f\u7528</li> </ul> <p>\u4eee\u60f3\u74b0\u5883\u306e\u4f5c\u6210</p> <pre><code>uv venv\n</code></pre> <p>\u4eee\u60f3\u74b0\u5883\u306e\u6709\u52b9\u5316</p> macOSWindows <pre><code>source .venv/bin/activate\n</code></pre> <pre><code>.venv\\Scripts\\activate\n</code></pre>"},{"location":"%E9%96%8B%E7%99%BA/Django/%E5%AE%9F%E8%A3%85%E3%83%A1%E3%83%A2/#_2","title":"\u4eee\u60f3\u74b0\u5883\u4f5c\u6210\u5f8c\u306e\u30bb\u30c3\u30c8\u30a2\u30c3\u30d7","text":"<ol> <li>Django\u306e\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb</li> </ol> <pre><code>uv pip install django\n</code></pre> <ol> <li>Django\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u306e\u4f5c\u6210</li> </ol> <pre><code>django-admin startproject &lt;project name&gt;\n</code></pre> <ol> <li>Django\u30a2\u30d7\u30ea\u30b1\u30fc\u30b7\u30e7\u30f3\u306e\u4f5c\u6210\uff08\u4efb\u610f\uff09</li> </ol> <pre><code>python manage.py startapp &lt;app name&gt;\n</code></pre> <ol> <li>DB\u30de\u30a4\u30b0\u30ec\u30fc\u30b7\u30e7\u30f3</li> </ol> <pre><code>python manege.py migrate\n</code></pre> <ol> <li>\u30b9\u30fc\u30d1\u30fc\u30e6\u30fc\u30b6\u30fc\u306e\u4f5c\u6210(\u7ba1\u7406\u7528\u753b\u9762)</li> </ol> <pre><code>python manage.py createsuperuser\n</code></pre> <ol> <li>\u958b\u767a\u30b5\u30fc\u30d0\u30fc\u306e\u8d77\u52d5</li> </ol> <pre><code>python manage.py runserver\n</code></pre> <ul> <li>port \u304c\u57cb\u307e\u3063\u3066\u3044\u308b\u5834\u5408\u306f\u3001runserver\u306e\u5f8c\u306bport\u6307\u5b9a\u3092\u3059\u308b\u3002</li> </ul> <pre><code>python manage.py runserver &lt;port\u756a\u53f7&gt;\n</code></pre>"},{"location":"%E9%96%8B%E7%99%BA/Django/%E5%AE%9F%E8%A3%85%E3%83%A1%E3%83%A2/#app","title":"app\u306e\u4f5c\u6210\u3068\u767b\u9332","text":"<p>app\u30b3\u30de\u30f3\u30c9\u5b9f\u884c\u5f8c\u3001djago/settings.py\u306b\u4f5c\u6210\u3057\u305fapp\u3092\u767b\u9332\u3059\u308b\u3002</p> <pre><code># Application definition\n\nINSTALLED_APPS = [\n    'django.contrib.admin',\n    'django.contrib.auth',\n    'django.contrib.contenttypes',\n    'django.contrib.sessions',\n    'django.contrib.messages',\n    'django.contrib.staticfiles',\n    'helloapp', #\u4f5c\u3063\u305fapp\u3092\u8ffd\u8a18\n]\n</code></pre>"},{"location":"%E9%96%8B%E7%99%BA/Django/%E5%AE%9F%E8%A3%85%E3%83%A1%E3%83%A2/#urlspy","title":"\u30a2\u30d7\u30ea\u30b1\u30fc\u30b7\u30e7\u30f3urls.py\u306e\u4f5c\u6210","text":"<p>Django\u3067\u306f\u3001\u30a2\u30d7\u30ea\u30b1\u30fc\u30b7\u30e7\u30f3\u3054\u3068\u306bURL\u306e\u30eb\u30fc\u30c6\u30a3\u30f3\u30b0\uff08\u3069\u306eURL\u3067\u51e6\u7406\u3092\u884c\u3046\u304b\uff09\u3092\u7ba1\u7406\u3059\u308b\u305f\u3081\u306b\u3001urls.py\u3068\u3044\u3046\u30d5\u30a1\u30a4\u30eb\u3092\u81ea\u5206\u3067\u4f5c\u308b\u5fc5\u8981\u304c\u3042\u308b\u3002</p> <p>app/urls.py</p> <pre><code># url\u30d1\u30bf\u30fc\u30f3\u3092\u5b9a\u7fa9\u3059\u308b\u305f\u3081\u306epath\u95a2\u6570\u3092\u30a4\u30f3\u30dd\u30fc\u30c8\nfrom django.urls import path\n#\u3000\u73fe\u5728\u306e\u30c7\u30a3\u30ec\u30af\u30c8\u30ea\u304b\u3089views\u30e2\u30b8\u30e5\u30fc\u30eb\u3092\u30a4\u30f3\u30dd\u30fc\u30c8\nfrom . import views\n\nurlpatterns = [\n    # 'hello/'\u304c\u30ea\u30af\u30a8\u30b9\u30c8\u3055\u308c\u305f\u3068\u304d\u3001\n    # views\u30e2\u30b8\u30e5\u30fc\u30eb\u306eshow_hello\u95a2\u6570\u3092\u547c\u3073\u51fa\u3059\u3002\n    path('hello/', views.show_hello, name='hello')\n]\n</code></pre>"},{"location":"%E9%96%8B%E7%99%BA/Django/%E5%AE%9F%E8%A3%85%E3%83%A1%E3%83%A2/#urlspy_1","title":"\u30d7\u30ed\u30b8\u30a7\u30af\u30c8urls.py\u306e\u4fee\u6b63","text":"<p>Django\u3067\u306f\u3001\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u5168\u4f53\u306eurls.py\u306b\u500b\u5225\u30a2\u30d7\u30ea\u306eURL\u30eb\u30fc\u30eb\u3092\u8ffd\u52a0\u3059\u308b\u969b\u306b\u300cinclude()\u95a2\u6570\u300d\u3092\u4f7f\u3063\u3066 \u3053\u306e\u5148\u306f\u30a2\u30d7\u30ea\u306e\u30eb\u30fc\u30eb\u306b\u4efb\u305b\u307e\u3059\u3002 \u3068\u6307\u5b9a\u3057\u307e\u3059\u3002</p> <p>myproject/urls.py</p> <pre><code># Django\u7ba1\u7406\u30b5\u30a4\u30c8\u7528\u306e\u30e2\u30b8\u30e5\u30fc\u30eb\u3092\u30a4\u30f3\u30dd\u30fc\u30c8\nfrom django.contrib import admin\n# url\u30d1\u30bf\u30fc\u30f3\u3092\u5b9a\u7fa9\u3059\u308b\u305f\u3081\u306epath\u95a2\u6570\u3068include\u95a2\u6570\u3092\u30a4\u30f3\u30dd\u30fc\u30c8\nfrom django.urls import path, include\n\nurlpatterns = [\n    # 'admin/'\u304c\u30ea\u30af\u30a8\u30b9\u30c8\u3055\u308c\u305f\u3068\u304d\u3001Django\u306e\u7ba1\u7406\u30b5\u30a4\u30c8\u3092\u8868\u793a\u3059\u308b\u3002\n    path('admin/', admin.site.urls),\n    # 'exe01/'\u304c\u30ea\u30af\u30a8\u30b9\u30c8\u3055\u308c\u305f\u3068\u304d\u3001helloapp\u30a2\u30d7\u30ea\u30b1\u30fc\u30b7\u30e7\u30f3\u306eurls\u30e2\u30b8\u30e5\u30fc\u30eb\u3092\u53c2\u7167\u3059\u308b\u3002\n    path('exe01/', include('helloapp.urls')),\n]\n</code></pre>"},{"location":"%E9%96%8B%E7%99%BA/Django/%E5%AE%9F%E8%A3%85%E3%83%A1%E3%83%A2/#viewspy","title":"\u30a2\u30d7\u30ea\u30b1\u30fc\u30b7\u30e7\u30f3views.py\u306e\u4fee\u6b63","text":"<p>\u30a2\u30d7\u30ea\u30b1\u30fc\u30b7\u30e7\u30f3\u5074\u306eviews.py\u306e\u4fee\u6b63\u3092\u884c\u3046</p> <p>app/views.py</p> <pre><code># HttpResponse\u30af\u30e9\u30b9\u3092\u30a4\u30f3\u30dd\u30fc\u30c8\nfrom django.http import HttpResponse\n\n\n# --------------------------------\n# \u30d3\u30e5\u30fc\u95a2\u6570\u3092\u5b9a\u7fa9\n# \"\u30cf\u30ed\u30fc\u3001Django!\"\u3068\u3044\u3046\u30c6\u30ad\u30b9\u30c8\u3092\u542b\u3080HTTP\u30ec\u30b9\u30dd\u30f3\u30b9\u3092\u8fd4\u3059\n# --------------------------------\n\ndef show_hello(request):\n    return HttpResponse(\"\u30cf\u30ed\u30fc\u3001Django!\")\n</code></pre> <p>Django\u306e\u30d3\u30e5\u30fc\u95a2\u6570\u306frequest\u5f15\u6570\u3092\u3068\u308b Django\u306e\u30d3\u30e5\u30fc\u95a2\u6570\u306f\u5fc5\u305arequest\u95a2\u6570\u3092\u53d6\u308a\u307e\u3059\u3002\u3053\u306e\u300crequest\u300d\u306f\u3001\u30e6\u30fc\u30b6\u30fc\u304b\u3089\u306eHTTP\u30ea\u30af\u30a8\u30b9\u30c8\uff08\u30af\u30e9\u30a4\u30a2\u30f3\u30c8\u304b\u3089\u30b5\u30fc\u30d0\u30fc\u304b\u3089\u306b\u9001\u3089\u308c\u308b\u30c7\u30fc\u30bf\u8981\u6c42\uff09\u3092\u8868\u3057\u307e\u3059\u3002</p> <ul> <li>request\u5f15\u6570\u306e\u7279\u5fb4 \u30d7\u30ed\u30b3\u30c8\u30eb\u306e\u4e00\u8cab\u6027 Django\u30d5\u30ec\u30fc\u30e0\u30ef\u30fc\u30af\u306f\u3001\u30d3\u30e5\u30fc\u95a2\u6570\u304cHTTP\u30ea\u30af\u30a8\u30b9\u30c8\u30aa\u30d6\u30b8\u30a7\u30af\u30c8\u3092\u5f15\u6570\u3068\u3057\u3066\u3001\u53d7\u3051\u53d6\u308b\u3053\u3068\u3092\u524d\u63d0\u3068\u3057\u3066\u3044\u307e\u3059\u3002\u3053\u308c\u306b\u3088\u308aDjango\u306f\u30ea\u30af\u30a8\u30b9\u30c8\u306b\u5bfe\u3059\u308b\u30ea\u30b9\u30dd\u30f3\u30b9\u3092\u9069\u5207\u306b\u51e6\u7406\u3057\u307e\u3059\u3002</li> </ul> <p>\u30ea\u30af\u30a8\u30b9\u30c8\u60c5\u5831\u3078\u306e\u30a2\u30af\u30bb\u30b9 \u30d3\u30e5\u30fc\u95a2\u6570\u5185\u3067request\u5f15\u6570\u3092\u4f7f\u7528\u3059\u308b\u3053\u3068\u3067\u3001\u30e6\u30fc\u30b6\u30fc\u306e\u30ea\u30af\u30a8\u30b9\u30c8\u306b\u95a2\u3059\u308b\u60c5\u5831\uff08\u4f8b\uff1aGET/POST\u30c7\u30fc\u30bf\u3001\u30af\u30c3\u30ad\u30fc\u3001\u30bb\u30c3\u30b7\u30e7\u30f3\u30c7\u30fc\u30bf\u306a\u3069\uff09\u306b\u30a2\u30af\u30bb\u30b9\u3067\u304d\u307e\u3059\u3002</p>"},{"location":"%E9%96%8B%E7%99%BA/Django/%E5%AE%9F%E8%A3%85%E3%83%A1%E3%83%A2/#_3","title":"\u30b5\u30fc\u30d0\u30fc\u306e\u8d77\u52d5\u3068\u78ba\u8a8d","text":"<p>manage.py\u306e\u3042\u308b\u30c7\u30a3\u30ec\u30af\u30c8\u30ea\u306b\u79fb\u52d5\u3057\u3001\u4e0b\u8a18\u306e\u30b3\u30de\u30f3\u30c9\u3092\u5b9f\u884c</p> <pre><code>python manage.py runserver\n</code></pre> <p>\u30d6\u30e9\u30a6\u30b6\u306b\u30a2\u30af\u30bb\u30b9\u5f8c\u3001\u6307\u5b9a\u3057\u305fURL\u3001\u3053\u3053\u3067\u306f\u3001\u300chttp://loclahost:8000/exe01/hello/\u300d\u3092\u5165\u529b\u3057\u3001\u8868\u793a\u3092\u78ba\u8a8d\u3059\u308b\u3002</p>"},{"location":"%E9%96%8B%E7%99%BA/Django/%E5%AE%9F%E8%A3%85%E3%83%A1%E3%83%A2/#django2","title":"Django\u306e2\u3064\u306e\u66f8\u304d\u65b9","text":"<p>Djangon\u306b\u306f2\u3064\u306e\u66f8\u304d\u65b9\u304c\u3042\u308b\u3002 - \u95a2\u6570\u30d9\u30fc\u30b9\u30d3\u30e5\u30fc\uff08FBV\uff09 - \u30af\u30e9\u30b9\u30d9\u30fc\u30b9\u30d3\u30e5\u30fc\uff08CBV\uff09</p> \u30d3\u30e5\u30fc\u306e\u7a2e\u985e \u8a73\u7d30 FBV \u95a2\u6570\u3092\u4f7f\u3063\u3066\u30d3\u30e5\u30fc\u3092\u5b9a\u7fa9\u3059\u308b\u65b9\u6cd5\u3002\u4e0a\u8a18\u306b\u793a\u3057\u305f\u4f8b\uff08helloapp\uff09 CBV \u30af\u30e9\u30b9\u3092\u4f7f\u3063\u3066\u30d3\u30e5\u30fc\u3092\u5b9a\u7fa9\u3059\u308b\u65b9\u6cd5\u3002\u3088\u308a\u67d4\u8edf\u3067\u518d\u5229\u7528\u6027\u306e\u9ad8\u3044\u8a2d\u8a08\u304c\u53ef\u80fd\u3067\u3059\u3002"},{"location":"%E9%96%8B%E7%99%BA/Python/Python_memo/","title":"Python index","text":"<p>\u3053\u3053\u3067\u306fPython\u306b\u7e8f\u308f\u308b\u3082\u306e\u3092\u6271\u3046</p>"},{"location":"%E9%96%8B%E7%99%BA/Python/Python_memo/#_1","title":"\u516c\u5f0f\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8","text":"<ul> <li>Python</li> <li>Django</li> <li>FastAPI</li> </ul>"},{"location":"%E9%96%8B%E7%99%BA/Python/Python_memo/#_2","title":"\u30e9\u30a4\u30d6\u30e9\u30ea\u7cfb\u516c\u5f0f\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8","text":"<ul> <li>markmap</li> <li>Mkdocs</li> </ul>"},{"location":"%E9%96%8B%E7%99%BA/%E3%83%A9%E3%82%A4%E3%83%96%E3%83%A9%E3%83%AA%E7%B3%BB/mkdocs/","title":"Mkdocs","text":"<p>\u3053\u306e\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u3092\u4f5c\u3063\u3066\u3044\u308b\u3082\u306emkdocs\u3067\u3059\u3002 - \u516c\u5f0f\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8</p> <p>Note</p> <p>\u958b\u767a\u6642\u306b\u6559\u3048\u3066\u3082\u3089\u3063\u305f\u3002\u958b\u767a\u6642\u306b\u306f\u30ea\u30dd\u30b8\u30c8\u30ea\u5185\u3067\u6d3b\u7528\u3057\u3066\u3044\u305f\u304c\u3001\u6539\u3081\u3066\u6d3b\u7528\u3059\u308b\u3068Sphinx\u3088\u308a\u3082\u6c17\u8efd\u304b\u3082\u3057\u308c\u306a\u3044\u3002</p>"},{"location":"%E9%96%8B%E7%99%BA/%E3%83%A9%E3%82%A4%E3%83%96%E3%83%A9%E3%83%AA%E7%B3%BB/mkdocs/#tip","title":"\u30de\u30fc\u30af\u30c0\u30a6\u30f3\u8a18\u6cd5Tip","text":"<ul> <li>\u6298\u308a\u305f\u305f\u307f</li> </ul> Note <p>\u30af\u30ea\u30c3\u30af\u3067\u8868\u793a\u3055\u308c\u307e\u3059</p> <ul> <li>\u30bf\u30d6\u8868\u793a</li> </ul> PythonBash <pre><code>print(\"hello\")\n</code></pre> <pre><code>echo hello\n</code></pre>"},{"location":"%E9%96%8B%E7%99%BA/%E3%83%A9%E3%82%A4%E3%83%96%E3%83%A9%E3%83%AA%E7%B3%BB/mkdocs/#_1","title":"\u95a2\u9023\u8a18\u4e8b","text":"<ul> <li>MkDocs\u3092\u4f7f\u3063\u3066\u3001\u7c21\u5358\u306b\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u516c\u958b\u266a</li> <li>MKDocs \u2013 \u62e1\u5f35\u30d7\u30e9\u30b0\u30a4\u30f3\u96c6(1)</li> </ul>"},{"location":"%E9%96%8B%E7%99%BA/%E3%83%A9%E3%82%A4%E3%83%96%E3%83%A9%E3%83%AA%E7%B3%BB/uv/","title":"uv","text":"<p>uv\u306fPython\u306e\u30d1\u30c3\u30b1\u30fc\u30b8\u7ba1\u7406\u30c4\u30fc\u30eb\u3067\u3001pip\u3084poetry\u3068\u540c\u3058\u3088\u3046\u306b\u4f7f\u3048\u308b\u3002Rust\u3067\u4f5c\u308c\u3089\u308c\u3066\u3044\u308b\u305f\u3081\u3068\u3066\u3082\u65e9\u3044\u3002</p>"},{"location":"%E9%96%8B%E7%99%BA/%E3%83%A9%E3%82%A4%E3%83%96%E3%83%A9%E3%83%AA%E7%B3%BB/uv/#_1","title":"\u30b3\u30de\u30f3\u30c9\u30ea\u30b9\u30c8","text":"\u30b3\u30de\u30f3\u30c9 \u51e6\u7406\u5185\u5bb9 uv --version \u30d0\u30fc\u30b8\u30e7\u30f3\u8868\u793a uv venv list \u4f5c\u3089\u308c\u3066\u3044\u308b\u4eee\u60f3\u74b0\u5883\u306e\u30ea\u30b9\u30c8\u3092\u8868\u793a uv venv \u30c7\u30d5\u30a9\u30eb\u30c8\u3067.venv\u4eee\u60f3\u74b0\u5883\u3092\u4f5c\u6210 uv venv &lt;\u7279\u5b9a\u306e\u540d\u524d&gt; \u7279\u5b9a\u306e\u540d\u524d\u3067\u4eee\u60f3\u74b0\u5883\u3092\u4f5c\u6210 source .venv/bin/activate \u4eee\u60f3\u74b0\u5883\u306e\u6709\u52b9\u5316\uff08Linux/macOS\uff09 .venv\\Scripts\\activate \u4eee\u60f3\u74b0\u5883\u306e\u6709\u52b9\u5316\uff08Windows\uff09 uv pip install  \u4eee\u60f3\u74b0\u5883\u306b\u30d1\u30c3\u30b1\u30fc\u30b8\u306e\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb uv pip list \u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\u6e08\u307f\u306e\u30d1\u30c3\u30b1\u30fc\u30b8\u4e00\u89a7"}]}